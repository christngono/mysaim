# ── Copier ce fichier en .env et remplir les valeurs ──────────────────────────

# Environnement (mettre "production" sur Hostinger)
NODE_ENV=production

# Port utilisé par Hostinger (laisser tel quel, Hostinger le fixe automatiquement)
PORT=5001

# Clé secrète JWT — CHANGER OBLIGATOIREMENT en production (min 32 caractères)
JWT_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_LONGUE_ET_ALEATOIRE

# URL du frontend (ton domaine Hostinger, ex: https://saim.cm)
# En mode production le backend sert lui-même le frontend, donc cette valeur
# sert uniquement à sécuriser CORS pour les appels API externes.
FRONTEND_URL=https://saim.cm

# ── CampPay (paiement mobile money) ──────────────────────────────────────────
# Créer un compte sur https://campay.net et récupérer les identifiants API
CAMPAY_APP_USERNAME=REMPLACER_PAR_USERNAME_CAMPAY
CAMPAY_APP_PASSWORD=REMPLACER_PAR_PASSWORD_CAMPAY
# Secret pour valider la signature des webhooks CampPay
CAMPAY_WEBHOOK_SECRET=REMPLACER_PAR_SECRET_WEBHOOK
